# ============================================================
#  CIVIC-DSS — Root .gitignore
#  Never commit secrets, credentials, or generated artifacts
# ============================================================

# ── Environment / Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
*.pyo

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
backend/.venv/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
dist/
dist-ssr/
frontend/dist/
*.local

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── ML Model Binary Artifacts ────────────────────────────────
# (Large files — share via cloud storage, not git)
backend/data/models/*.pkl
backend/data/models/*.joblib
backend/data/models/*.npy
# Keep .json model and metadata files (they are needed for inference)
# Keep .csv files for SHAP and preprocessing reference

# ── Raw / Processed Data ─────────────────────────────────────
backend/data/raw/*
backend/data/processed/*
data/raw/*
data/processed/*

# ── OS Artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
